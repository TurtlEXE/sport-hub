# ==========================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG DỰ ÁN (Tham khảo)
# ==========================================
# Copy file này thành .env hoặc thiết lập thẳng vào biến môi trường hệ thống của bạn (OS Environment Variables).

# Database 
DB_USERNAME=root
DB_PASSWORD=your_db_password

# JWT Security
# Mật khẩu dùng để mã hoá Token (phải dài và bảo mật)
JWT_SECRET=your_jwt_secret_key_needs_to_be_long_and_secure_for_production_min_256_bits_for_hs256

# Gmail SMTP 
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# OAuth2 Google & Facebook (Login bằng MXH)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
